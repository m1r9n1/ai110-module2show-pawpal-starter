classDiagram
    class Owner {
        +String name
        +String email
        +String phone
        +List~Pet~ pets
        +addPet(pet) void
        +removePet(petId) void
        +getSchedule() Schedule
    }

    class Pet {
        +String name
        +String species
        +String breed
        +int age
        +String medicalNotes
        +List~Task~ tasks
        +addTask(task) void
        +getUpcomingTasks() List~Task~
    }

    class Task {
        +String title
        +String description
        +String category
        +boolean isCompleted
        +complete() void
        +reset() void
    }

    class Schedule {
        +List~Task~ scheduledTasks
        +Date startDate
        +Date endDate
        +addTask(task, dateTime) void
        +removeTask(taskId) void
        +getTasksForDay(date) List~Task~
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Owner "1" --> "1" Schedule : manages
    Schedule "1" --> "many" Task : contains
